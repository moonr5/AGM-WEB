  <script>
    window.currentScroll = 0;
    window.targetScroll = 0;
    const ease = 0.08;
    const mouseSpeed = 1;

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    const maxScroll = () =>
      Math.max(
        document.documentElement.scrollHeight,
        document.body.scrollHeight,
      ) - window.innerHeight;

    window.addEventListener(
      'wheel',
      (e) => {
        if (
          e.target.closest('.maplibregl-canvas') ||
          e.target.closest('.cardContainer')
        ) {
          requestAnimationFrame(() => {
            window.currentScroll = window.scrollY;
            window.targetScroll = window.scrollY;
          });
          return;
        }

        e.preventDefault();
        window.targetScroll += e.deltaY * mouseSpeed;
        window.targetScroll = clamp(window.targetScroll, 0, maxScroll());
      },
      { passive: false },
    );

    function smoothScroll() {
      const diff = window.targetScroll - window.currentScroll;
      if (Math.abs(diff) > 0.5) {
        window.currentScroll += diff * ease;
        window.scrollTo(0, Math.round(window.currentScroll));
      }
      requestAnimationFrame(smoothScroll);
    }

    smoothScroll();
  </script>
