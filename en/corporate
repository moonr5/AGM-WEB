  // rimuove tutte le altre
  [corporate, med, apac, slota, preowned].forEach((appbar) => {
    if (appbar !== activeAppbar) {
      appbar?.remove();
    }
  });

  console.log("hostname:", host);
  console.log("active:", activeAppbar.id);
