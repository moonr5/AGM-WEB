{
  "name": "agm-local-site",
  "version": "1.0.0",
  "private": true,
  "description": "Local runner for the Agara Global Maritim static website backup.",
  "scripts": {
    "start": "node local-server.js",
    "prepare": "node tools/prepare-local-site.js",
    "audit": "node tools/prepare-local-site.js --audit-only",
    "audit:unused": "node tools/audit-unused-files.js",
    "clean:unused": "node tools/delete-unused-files.js && node tools/audit-unused-files.js"
  }
}
